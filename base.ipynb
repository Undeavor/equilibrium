import matplotlib.pyplot as plt 
import numpy as np
#Initialisation des constantes 
nb_agents=1000
nb_secteurs=10
#Génération matrice aléatoire Pij

#Productivité 
#Cas loi uniforme
P=np.random.uniform(0,1,(nb_agents,nb_secteurs))

A_brut = np.random.uniform(0, 1, (nb_agents, nb_secteurs))
A = A_brut / A_brut.sum(axis=1, keepdims=True)

Pi=np.ones(nb_secteurs)
#Calcul des revenus potentiels et budgets
def Y(P,Pi):
    return P*Pi #produit terme à terme possible avec numpy

def J(Y): #choix de secteur de i
    return np.argmax(Y, axis=1)

def B(P,Pi):
    return np.max(Y(P,Pi), axis=1)

#Offre et demande en valeur

def Offre(P,Pi):
    Omega = np.zeros(nb_secteurs)
    for j in range(nb_secteurs):
        for i in range(nb_agents):
            if J(Y(P,Pi))[i]==j:
                Omega[j]=P[i][j]*Pi[j]
    return Omega

def Demande(A,B):
    return B@A

#calcul des espérances 

#on a bien A et Pi fixés

def esperances(P,A,Pi,n=100000):
    #Cas loi uniforme
    acc_Offre=0
    acc_Demande=0
    for i in range(n):
        P=np.random.uniform(0,1,(nb_agents,nb_secteurs))
        acc_Offre+=Offre(P,Pi)
        acc_Demande+=Demande(A,B(P,Pi))
    return [acc_Offre/n, acc_Demande/n]
#Résolution pour obtenir Pi solution de l'égalité des espérances

#algo naif
n=0
epsilon=10
[E_offre, E_demande] = [0, 0]
def algo_tatonnement(A,Pi, n_iter=200, learning_rate=0.01):
    historique_prix = []
    
    for i in range(n_iter):
        E_Offre, E_Demande = esperances(P,A,Pi)
        Pi = Pi + learning_rate * (E_Demande - E_Offre)

        Pi = np.maximum(Pi, 0.001) 

        Pi = Pi / np.sum(Pi) * nb_secteurs 
        
        historique_prix.append(Pi.copy())

        erreur = np.max(np.abs(E_Demande - E_Offre))
        if erreur < 1.0: 
            print(f"Équilibre atteint à l'itération {i}")
            break
            
    return Pi, np.array(historique_prix)


